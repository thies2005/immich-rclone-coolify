# ════════════════════════════════════════════════════════════════════
# Immich + Internxt rclone — Docker Standalone Environment
# ════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Only DB_PASSWORD is required. Everything else has working defaults.

# ── Database (REQUIRED) ──────────────────────────────────────────

DB_PASSWORD=change-me-to-a-strong-random-password
# DB_USERNAME=immich
# DB_DATABASE_NAME=immich

# ── Immich ───────────────────────────────────────────────────────

# Pin to a specific release for reproducibility (e.g. v2.1.0)
# IMMICH_VERSION=v2

# Port for direct HTTP access (when not using a reverse proxy)
# IMMICH_PORT=2283

# ── Reverse Proxy (choose ONE) ───────────────────────────────────
#
# Uncomment the corresponding service in docker-compose.standalone.yml
# after configuring your chosen option below.

# Option A: Caddy (automatic HTTPS via Let's Encrypt)
# Requires: DOMAIN pointing to your server's public IP (A record)
# DOMAIN=photos.example.com
# CADDY_ACME_EMAIL=admin@example.com

# Option B: Cloudflare Tunnel
# Requires: TUNNEL_TOKEN from https://one.dash.cloudflare.com
# Create a tunnel with public hostname -> http://immich-server:2283
# CLOUDFLARE_TOKEN=your-tunnel-token-here

# Option C: Tailscale Serve
# Requires: TS_AUTHKEY from https://login.tailscale.com/admin/settings/keys
# Check "Reusable" so the key can be used after first auth
# TS_AUTHKEY=tskey-auth-your-key-here
