# ════════════════════════════════════════════════════════════════════
# Immich + Internxt rclone — Docker Standalone Environment
# ════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Only DB_PASSWORD is required. Everything else has working defaults.

# ── Database (REQUIRED) ──────────────────────────────────────────

DB_PASSWORD=change-me-to-a-strong-random-password
# DB_USERNAME=immich
# DB_DATABASE_NAME=immich

# ── Immich ───────────────────────────────────────────────────────

# Pin to a specific release for reproducibility (e.g. v2.1.0)
# IMMICH_VERSION=v2

# Port for direct HTTP access (when not using a reverse proxy)
# IMMICH_PORT=2283

# ── Reverse Proxy (choose ONE) ───────────────────────────────────
#
# Uncomment the corresponding service in docker-compose.standalone.yml
# after configuring your chosen option below.

# Option A: Caddy (automatic HTTPS via Let's Encrypt)
# Requires: DOMAIN pointing to your server's public IP (A record)
# DOMAIN=photos.example.com
# CADDY_ACME_EMAIL=admin@example.com

# Option B: Cloudflare Tunnel
# Requires: TUNNEL_TOKEN from https://one.dash.cloudflare.com
# Create a tunnel with public hostname -> http://immich-server:2283
# CLOUDFLARE_TOKEN=your-tunnel-token-here

# Option C: Tailscale Serve
# Requires: TS_AUTHKEY from https://login.tailscale.com/admin/settings/keys
# Check "Reusable" so the key can be used after first auth
# TS_AUTHKEY=tskey-auth-your-key-here

# ── Machine Learning Load Balancer (internal only) ───────────────

# For Coolify, set these in your resource environment variables.
# For standalone Docker, set them in .env.

# Balancing mode:
# - round_robin (default)
# - weighted     (uses ML_BACKEND_X_WEIGHT)
# - least_conn
# - ip_hash
# ML_LB_METHOD=round_robin

# Upstream failure handling / retries
# ML_BACKEND_MAX_FAILS=2
# ML_BACKEND_FAIL_TIMEOUT=10s
# ML_PROXY_CONNECT_TIMEOUT=3s
# ML_PROXY_SEND_TIMEOUT=300s
# ML_PROXY_READ_TIMEOUT=300s
# ML_PROXY_NEXT_UPSTREAM_TRIES=3
# ML_LB_KEEPALIVE=32

# Backends accept host:port or full URLs. Keep all real hostnames/IPs in .env, never in compose.
# Examples:
#   immich-machine-learning:3003
#   192.168.1.50:3003
#   ml-remote.example.internal:3003
#   https://immich-ml.example.com
# HTTPS backends are automatically detected and proxied with TLS.

# At least one backend should be set.
# ML_BACKEND_1=immich-machine-learning:3003
# ML_BACKEND_1_WEIGHT=1
# ML_BACKEND_2=
# ML_BACKEND_2_WEIGHT=1
# ML_BACKEND_3=
# ML_BACKEND_3_WEIGHT=1
# ML_BACKEND_4=
# ML_BACKEND_4_WEIGHT=1
# ML_BACKEND_5=
# ML_BACKEND_5_WEIGHT=1
# ML_BACKEND_6=
# ML_BACKEND_6_WEIGHT=1
# ML_BACKEND_7=
# ML_BACKEND_7_WEIGHT=1
# ML_BACKEND_8=
# ML_BACKEND_8_WEIGHT=1
# ML_BACKEND_9=
# ML_BACKEND_9_WEIGHT=1
# ML_BACKEND_10=
# ML_BACKEND_10_WEIGHT=1

# ── Machine Learning Runtime Tuning (prevent worker OOM/restarts) ──

# Keep worker count low on small hosts (each worker duplicates model memory).
# MACHINE_LEARNING_WORKERS=1

# Reduce concurrency to lower RAM pressure while loading large models.
# MACHINE_LEARNING_REQUEST_THREADS=1
# MACHINE_LEARNING_MODEL_INTER_OP_THREADS=1
# MACHINE_LEARNING_MODEL_INTRA_OP_THREADS=1

# Increase timeout so workers are not killed during first-time model downloads/loads.
# MACHINE_LEARNING_WORKER_TIMEOUT=300
